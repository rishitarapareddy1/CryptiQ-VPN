{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CryptiQ Personal",
  "version": "0.4.0",
  "identifier": "com.cryptiq.personal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CryptiQ Personal",
        "width": 1180,
        "height": 780,
        "minWidth": 980,
        "minHeight": 660,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": ["icons/icon.icns", "icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
